<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Parent is Theme.AppCompat.DayNight.NoActionBar — needed because
        MainActivity extends AppCompatActivity (so AppCompatDelegate.setApplicationLocales
        works on Android <13). Compose draws its own UI so the AppCompat parent
        only contributes window flags + AppCompat's per-app locale plumbing.
    -->
    <style name="Theme.AgroSphere" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/brand_bg</item>
    </style>

    <style name="Theme.AgroSphere.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.AgroSphere</item>
    </style>
</resources>
